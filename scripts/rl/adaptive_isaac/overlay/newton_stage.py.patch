+        with open(_ADAPTIVE_LOG_PATH, "a") as _fh:
+            _fh.write(f"[{_ovl_time.time():.3f}] [ADAPTIVE OVERLAY] {msg}\n")
+    except Exception:
+        pass
+
+
+def _ovl_truthy(val) -> bool:
+    """Interpret a config value or env string as a boolean flag."""
+    if isinstance(val, str):
+        return val.strip().lower() in ("1", "true", "yes", "on")
+    return bool(val)
+
