+# Default /tmp/newton_adaptive.log; override with $NEWTON_ADAPTIVE_LOG. Every helper is wrapped in a
+# broad try/except so instrumentation can never take down the sim (it is diagnostics, not logic).
+_ADAPTIVE_LOG_PATH = _ovl_os.environ.get("NEWTON_ADAPTIVE_LOG", "/tmp/newton_adaptive.log")
