+    def _ovl_log_adaptive_telemetry(self, step_dt: float) -> None:
+        """[ADAPTIVE OVERLAY] Append per-frame adaptive telemetry to $NEWTON_ADAPTIVE_LOG.
+
+        Fires every ``NEWTON_ADAPTIVE_LOG_EVERY`` frames (default 30) and is fully guarded so a bad
+        read can never break the sim. The host-syncing ``.numpy()`` reads are intentionally rare
+        (once per N frames, never per substep) to stay out of the physics hot path.
+
+        Args:
+            step_dt: The outer frame dt passed to ``step_dt`` this frame [s].
+        """
+        try:
+            every = int(_ovl_os.environ.get("NEWTON_ADAPTIVE_LOG_EVERY", "30"))
+        except Exception:
+            every = 30
+        if every <= 0:
+            return
+        frame = getattr(self, "simulation_step_count", 0)
+        if frame % every != 0:
+            return
+
+        try:
+            solver = self.solver
+            # Per-world current dt [s] -- the headline "is it adapting?" signal. Across worlds in
+            # per_world mode these diverge once accept/reject decisions differ; frame-to-frame they
+            # move as contact density changes. A flat min==max that never changes => not adapting.
+            dt_arr = solver.dt.numpy()
+            dt_min = float(dt_arr.min())
+            dt_max = float(dt_arr.max())
+
+            # cumulative_substeps() = iterations*3; the per-frame delta is how much MuJoCo work this
+            # frame's adaptive loop actually did. More substeps in a frame => the controller shrank dt.
+            cum = solver.cumulative_substeps()
+            prev = getattr(self, "_ovl_prev_cum_substeps", 0)
+            delta = cum - prev
+            self._ovl_prev_cum_substeps = cum
+
+            # Boundary-loop iterations for the most recent step_dt (one int32, on device).
+            try:
+                iters = int(solver.iteration_count.numpy()[0])
+            except Exception:
+                iters = -1
+
+            _ovl_log(
+                f"frame={frame} outer_dt={step_dt:.6f} "
+                f"inner_dt[min={dt_min:.3e} max={dt_max:.3e} spread={dt_max - dt_min:.3e}] "
+                f"iters_last={iters} substeps_frame={delta} substeps_cum={cum}"
+            )
+        except Exception as _e:  # diagnostics must never crash the sim
+            _ovl_log(f"telemetry read failed: {_e!r}")
