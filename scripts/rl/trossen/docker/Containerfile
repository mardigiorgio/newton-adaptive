# Isaac Sim 5.1 + Isaac Lab on an Ubuntu 22.04 base (supported userland).
# Built to run on a Fedora host via rootless podman with GPU passthrough (CDI).
# Run with:  --device nvidia.com/gpu=all --security-opt=label=disable
#
# Isaac Lab + trossen_ai_isaac are installed at runtime into a mounted workspace
# (not baked in) so we can iterate without rebuilding the heavy base image.
FROM docker.io/library/ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
# Add the deadsnakes PPA directly (Python 3.11 on Ubuntu 22.04) without
# add-apt-repository, whose GPG keyring import fails in a minimal container.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git ffmpeg && \
    echo "deb [trusted=yes] https://ppa.launchpadcontent.net/deadsnakes/ppa/ubuntu jammy main" \
        > /etc/apt/sources.list.d/deadsnakes.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3.11-dev \
        libgl1 libglu1-mesa libegl1 libxext6 libsm6 libice6 libxrender1 \
        libglib2.0-0 libvulkan1 vulkan-tools libxkbcommon0 libxrandr2 \
        libxcursor1 libxinerama1 libxi6 libxt6 && \
    rm -rf /var/lib/apt/lists/*

# Accept the Omniverse EULA non-interactively (required to run Isaac Sim headless).
ENV OMNI_KIT_ACCEPT_EULA=YES
ENV PATH=/opt/venv/bin:$PATH

RUN python3.11 -m venv /opt/venv && \
    pip install --upgrade pip wheel setuptools && \
    pip install "isaacsim[all,extscache]==5.1.0" --extra-index-url https://pypi.nvidia.com && \
    pip install torch==2.7.0 torchvision==0.22.0 --index-url https://download.pytorch.org/whl/cu128

WORKDIR /workspace
